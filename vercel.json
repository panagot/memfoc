{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pip install -r requirements.txt && cd demo/web && npm ci",
  "buildCommand": "sh scripts/vercel_build.sh",
  "env": {
    "PYTHONPATH": "."
  },
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "includeFiles": "src/**,demo/**"
    }
  }
}
